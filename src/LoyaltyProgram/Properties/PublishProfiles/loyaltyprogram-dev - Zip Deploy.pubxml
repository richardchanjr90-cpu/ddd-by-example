<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>ZipDeploy</WebPublishMethod>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>http://loyaltyprogram-dev.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>False</LaunchSiteAfterPublish>
    <ResourceId>/subscriptions/67baa471-7e9b-4c02-a4de-73ad955c0c72/resourceGroups/LoyaltyBackend-dev/providers/Microsoft.Web/sites/loyaltyprogram-dev</ResourceId>
    <UserName>$loyaltyprogram-dev</UserName>
    <_SavePWD>True</_SavePWD>
    <PublishUrl>https://loyaltyprogram-dev.scm.azurewebsites.net/</PublishUrl>
  </PropertyGroup>
</Project>